{
    "name": "ux2dev/microinvest",
    "description": "Framework-agnostic PHP SDK for the Microinvest Warehouse Pro REST API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "guzzlehttp/guzzle": "^7.0",
        "orchestra/testbench": "^10.0"
    },
    "suggest": {
        "guzzlehttp/guzzle": "Supplies PSR-18 client + PSR-17 factories out of the box",
        "illuminate/support": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Ux2Dev\\Microinvest\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ux2Dev\\Microinvest\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ux2Dev\\Microinvest\\Laravel\\MicroinvestServiceProvider"
            ],
            "aliases": {
                "Microinvest": "Ux2Dev\\Microinvest\\Laravel\\Facades\\Microinvest"
            }
        }
    },
    "minimum-stability": "stable",
    "scripts": {
        "test": "pest",
        "test:coverage": "pest --coverage --min=100"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
